# readable-mcp configuration. Copy to `.env` and adjust as needed.
# All variables are optional; defaults shown are production-sane. No secrets required.

# --- Rate limiting (token bucket) ---
READABLE_MCP_RATE_LIMIT_RPS=5            # sustained outbound requests per second
READABLE_MCP_RATE_LIMIT_BURST=10        # max burst (bucket capacity)

# --- Retries with exponential backoff ---
READABLE_MCP_MAX_RETRIES=3              # total attempts per fetch (incl. the first)
READABLE_MCP_RETRY_BASE_DELAY=0.5       # base backoff delay in seconds

# --- Timeouts (seconds) ---
READABLE_MCP_CONNECT_TIMEOUT=5          # connection establishment timeout
READABLE_MCP_READ_TIMEOUT=15            # socket read timeout
READABLE_MCP_TOTAL_TIMEOUT=20           # hard ceiling for a single request

# --- Response cache ---
READABLE_MCP_CACHE_TTL=900              # cache entry lifetime in seconds
READABLE_MCP_CACHE_MAXSIZE=512          # max cached entries (LRU/TTL eviction)

# --- Batch limits ---
READABLE_MCP_MAX_BATCH_URLS=10          # max URLs processed per extract_batch call

# --- Outbound identity ---
READABLE_MCP_USER_AGENT=readable-mcp/0.1 (+https://github.com/dantomescu/readable-mcp)

# --- Logging ---
READABLE_MCP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
